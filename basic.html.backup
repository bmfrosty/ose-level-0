<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OSE Basic Character Generator (Levels 1+)</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        nav {
            background-color: #f0f0f0;
            padding: 15px;
            margin-bottom: 20px;
            border-radius: 5px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        nav .nav-left {
            display: flex;
            gap: 20px;
        }
        nav a {
            text-decoration: none;
            color: #333;
            font-weight: bold;
        }
        nav a:hover {
            color: #4CAF50;
        }
        nav a.active {
            color: #4CAF50;
            text-decoration: underline;
        }
        
        .generator-container {
            background-color: #f8f9fa;
            border: 2px solid #4CAF50;
            border-radius: 5px;
            padding: 30px;
            margin: 20px 0;
        }
        
        .control-section {
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #ddd;
        }
        
        .control-section:last-child {
            border-bottom: none;
        }
        
        .control-section h3 {
            margin-top: 0;
            color: #333;
        }
        
        /* Level Selection - Radio Buttons */
        .level-selection {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }
        
        .level-radio {
            display: inline-flex;
            align-items: center;
        }
        
        .level-radio input[type="radio"] {
            margin-right: 5px;
        }
        
        .level-radio label {
            cursor: pointer;
            padding: 5px 10px;
            border: 1px solid #ccc;
            border-radius: 3px;
            background-color: white;
        }
        
        .level-radio input[type="radio"]:checked + label {
            background-color: #4CAF50;
            color: white;
            border-color: #4CAF50;
        }
        
        /* Class Selection - Row of Buttons */
        .class-selection {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }
        
        .class-button {
            padding: 12px 20px;
            font-size: 16px;
            font-weight: bold;
            border: 2px solid #4CAF50;
            border-radius: 5px;
            background-color: white;
            color: #4CAF50;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .class-button:hover {
            background-color: #e8f5e9;
        }
        
        .class-button.selected {
            background-color: #4CAF50;
            color: white;
        }
        
        .class-button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            border-color: #ccc;
            color: #ccc;
        }
        
        /* Checkboxes */
        .checkbox-option {
            margin: 15px 0;
        }
        
        .checkbox-option label {
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .checkbox-option input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }
        
        /* Generate Button */
        .generate-button {
            padding: 15px 30px;
            font-size: 18px;
            font-weight: bold;
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        
        .generate-button:hover {
            background-color: #45a049;
        }
        
        .generate-button:disabled {
            background-color: #ccc;
            cursor: not-allowed;
        }
        
        /* Ability Score Grid - 2 rows of 3 */
        .ability-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-top: 15px;
            max-width: 600px;
        }
        
        .ability-box {
            text-align: center;
        }
        
        .ability-label {
            font-weight: bold;
            display: block;
            margin-bottom: 5px;
            color: #333;
        }
        
        .ability-input {
            width: 80px;
            padding: 10px;
            text-align: center;
            border: 2px solid #ccc;
            border-radius: 3px;
            font-size: 18px;
            font-weight: bold;
        }
        
        .ability-input:focus {
            outline: none;
            border-color: #4CAF50;
        }
        
        .ability-modifier {
            display: block;
            margin-top: 5px;
            font-size: 14px;
            color: #666;
            font-weight: normal;
        }
        
        .xp-bonus-display {
            margin-top: 20px;
            padding: 15px;
            background-color: #e8f5e9;
            border-left: 4px solid #4CAF50;
            border-radius: 3px;
        }
        
        .xp-bonus-display strong {
            color: #2e7d32;
        }
        
        /* Roll Button */
        .roll-button {
            padding: 10px 20px;
            font-size: 16px;
            font-weight: bold;
            background-color: #2196F3;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s;
            margin-top: 15px;
        }
        
        .roll-button:hover {
            background-color: #1976D2;
        }
        
        .roll-button:disabled {
            background-color: #ccc;
            cursor: not-allowed;
        }
        
        /* Character Display */
        .character-display {
            background-color: white;
            border: 2px solid #4CAF50;
            border-radius: 5px;
            padding: 20px;
            margin-top: 20px;
            display: none;
        }
        
        .character-display.visible {
            display: block;
        }
        
        .character-display h2 {
            margin-top: 0;
            color: #4CAF50;
        }
        
        .info-note {
            background-color: #e7f3ff;
            border-left: 4px solid #2196F3;
            padding: 15px;
            margin: 15px 0;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <nav>
        <div class="nav-left">
            <a href="index.html">Level 0 Generator</a>
            <a href="basic.html" class="active">Basic (Levels 1+)</a>
            <a href="advanced.html">Advanced (Levels 1+)</a>
            <a href="classes.html">Class Reference</a>
        </div>
        <a href="about.html">About</a>
    </nav>

    <h1>OSE Basic Character Generator (Levels 1+)</h1>
    
    <div class="info-note">
        <strong>Basic Mode</strong> uses the traditional OSE race-as-class system where Dwarf, Elf, Halfling, and Gnome are classes (not races).
    </div>

    <div class="generator-container">
        <!-- Level Selection -->
        <div class="control-section">
            <h3>1. Select Level</h3>
            <div class="level-selection" id="levelSelection">
                <!-- Radio buttons 1-14 will be generated here -->
            </div>
        </div>

        <!-- Mode Toggle -->
        <div class="control-section">
            <h3>2. Select Mode & Options</h3>
            <div class="checkbox-option">
                <label>
                    <input type="checkbox" id="smoothifiedMode" checked>
                    <span>
                        <strong>Smoothified Mode</strong> 
                        (<a href="https://www.drivethrurpg.com/en/product/510225/the-ruins-of-castle-gygar" target="_blank">Castle Gygar</a>)
                        - Smoother progressions, no demihuman level limits
                    </span>
                </label>
            </div>
            <div class="checkbox-option">
                <label>
                    <input type="checkbox" id="toughCharacters">
                    <span>
                        <strong>Tough Characters</strong> - Require at least one of STR/DEX/INT/WIS ≥ 13
                    </span>
                </label>
            </div>
            <div class="checkbox-option">
                <label>
                    <input type="checkbox" id="healthyCharacters">
                    <span>
                        <strong>Healthy Characters</strong> - Require HP ≥ 2 at initial level (level 0 or level 1)
                    </span>
                </label>
            </div>
            <div class="checkbox-option">
                <label>
                    <input type="checkbox" id="includeLevel0HP">
                    <span>
                        <strong>Include Level 0 HP</strong> - Add 1d4+CON modifier to total HP (represents 0-level experience)
                    </span>
                </label>
            </div>
        </div>

        <!-- Ability Scores -->
        <div class="control-section">
            <h3>3. Ability Scores</h3>
            
            <div class="ability-grid">
                <!-- Row 1: STR, INT, WIS -->
                <div class="ability-box">
                    <label class="ability-label" for="scoreSTR">STR</label>
                    <input type="number" class="ability-input" id="scoreSTR" value="3" min="3" max="18">
                    <span class="ability-modifier" id="modSTR">+0</span>
                </div>
                <div class="ability-box">
                    <label class="ability-label" for="scoreINT">INT</label>
                    <input type="number" class="ability-input" id="scoreINT" value="3" min="3" max="18">
                    <span class="ability-modifier" id="modINT">+0</span>
                </div>
                <div class="ability-box">
                    <label class="ability-label" for="scoreWIS">WIS</label>
                    <input type="number" class="ability-input" id="scoreWIS" value="3" min="3" max="18">
                    <span class="ability-modifier" id="modWIS">+0</span>
                </div>
                
                <!-- Row 2: DEX, CON, CHA -->
                <div class="ability-box">
                    <label class="ability-label" for="scoreDEX">DEX</label>
                    <input type="number" class="ability-input" id="scoreDEX" value="3" min="3" max="18">
                    <span class="ability-modifier" id="modDEX">+0</span>
                </div>
                <div class="ability-box">
                    <label class="ability-label" for="scoreCON">CON</label>
                    <input type="number" class="ability-input" id="scoreCON" value="3" min="3" max="18">
                    <span class="ability-modifier" id="modCON">+0</span>
                </div>
                <div class="ability-box">
                    <label class="ability-label" for="scoreCHA">CHA</label>
                    <input type="number" class="ability-input" id="scoreCHA" value="3" min="3" max="18">
                    <span class="ability-modifier" id="modCHA">+0</span>
                </div>
            </div>
            
            <div class="xp-bonus-display" id="xpBonusDisplay" style="display: none;">
                <strong>Prime Requisite XP Bonus:</strong> <span id="xpBonusText">+0%</span>
            </div>
            
            <div class="checkbox-option">
                <label>
                    <input type="checkbox" id="useFixedScores">
                    <span><strong>Use fixed ability scores</strong> - Use the values above as-is (unchecked = roll randomly with minimums)</span>
                </label>
            </div>
            
            <button class="roll-button" id="rollAbilitiesButton">Roll Abilities</button>
            <button class="roll-button" id="testHPButton" style="margin-left: 10px; background-color: #FF9800;">Test HP Rolling</button>
            <div id="testHPWarning" style="margin-top: 10px; padding: 10px; background-color: #fff3cd; border-left: 4px solid #ffc107; display: none;">
                <strong>Cannot test HP rolling:</strong> <span id="testHPWarningText"></span>
            </div>
        </div>

        <!-- Class Selection -->
        <div class="control-section">
            <h3>4. Select Class</h3>
            <div class="class-selection" id="classSelection">
                <button class="class-button" data-class="Cleric">Cleric</button>
                <button class="class-button" data-class="Fighter">Fighter</button>
                <button class="class-button" data-class="Magic-User">Magic-User</button>
                <button class="class-button" data-class="Thief">Thief</button>
                <button class="class-button" data-class="Dwarf">Dwarf</button>
                <button class="class-button" data-class="Elf">Elf</button>
                <button class="class-button" data-class="Halfling">Halfling</button>
                <button class="class-button" data-class="Gnome">Gnome</button>
                <button class="class-button" data-class="Spellblade" id="spellbladeButton" style="display: none;">Spellblade</button>
            </div>
            
            <div class="checkbox-option">
                <label>
                    <input type="checkbox" id="allowDemihumanOverride">
                    <span>Allow demihuman levels above maximum (Dwarf 13-14, Elf 11-14, Halfling/Gnome 9-14)</span>
                </label>
            </div>
            
            <div class="checkbox-option">
                <label>
                    <input type="checkbox" id="allowElfSpellbladePast10">
                    <span>Allow Elf and Spellblade past level 10 (extends to level 14)</span>
                </label>
            </div>
        </div>

        <!-- Generate Button -->
        <div class="control-section">
            <h3>5. Generate</h3>
            <button class="generate-button" id="generateButton" disabled>Generate Character</button>
        </div>
    </div>

    <!-- Character Display -->
    <div class="character-display" id="characterDisplay">
        <h2>Generated Character</h2>
        <div id="characterInfo">
            <!-- Character details will be displayed here -->
        </div>
    </div>

    <script type="module">
        // Import class data modules
        import * as ClassDataOSE from './class-data-ose.js';
        import * as ClassDataGygar from './class-data-gygar.js';
        import * as ClassDataShared from './class-data-shared.js';
        
        // Make modules available globally for debugging
        window.ClassDataOSE = ClassDataOSE;
        window.ClassDataGygar = ClassDataGygar;
        window.ClassDataShared = ClassDataShared;
        
        console.log('Class data modules loaded successfully');
        console.log('OSE module:', ClassDataOSE);
        console.log('Gygar module:', ClassDataGygar);
        console.log('Shared module:', ClassDataShared);
        
        // State
        let selectedLevel = null;
        let selectedClass = null;
        let smoothifiedMode = true;
        let allowDemihumanOverride = false;
        let allowElfSpellbladePast10 = false;
        let toughCharacters = false;
        let healthyCharacters = false;
        let includeLevel0HP = false;
        let useFixedScores = false;
        
        // Ability scores state
        let abilityScores = {
            STR: 3,
            INT: 3,
            WIS: 3,
            DEX: 3,
            CON: 3,
            CHA: 3
        };
        
        // Minimum scores (read from input fields when rolling)
        let minimumScores = {
            STR: 3,
            INT: 3,
            WIS: 3,
            DEX: 3,
            CON: 3,
            CHA: 3
        };

        // Initialize level selection (radio buttons 1-14)
        function initializeLevelSelection() {
            const container = document.getElementById('levelSelection');
            for (let i = 1; i <= 14; i++) {
                const radioDiv = document.createElement('div');
                radioDiv.className = 'level-radio';
                
                const radio = document.createElement('input');
                radio.type = 'radio';
                radio.name = 'level';
                radio.id = `level${i}`;
                radio.value = i;
                
                const label = document.createElement('label');
                label.htmlFor = `level${i}`;
                label.textContent = i;
                
                radio.addEventListener('change', () => {
                    selectedLevel = parseInt(radio.value);
                    updateUI();
                });
                
                radioDiv.appendChild(radio);
                radioDiv.appendChild(label);
                container.appendChild(radioDiv);
            }
        }

        // Initialize class selection
        function initializeClassSelection() {
            const buttons = document.querySelectorAll('.class-button');
            buttons.forEach(button => {
                button.addEventListener('click', () => {
                    // Deselect all buttons
                    buttons.forEach(b => b.classList.remove('selected'));
                    // Select clicked button
                    button.classList.add('selected');
                    selectedClass = button.dataset.class;
                    updateUI();
                });
            });
        }

        // Check if HP rolling is possible
        function canRollHP() {
            const reasons = [];
            
            // Check if level is selected
            if (!selectedLevel) {
                reasons.push('No level selected');
            }
            
            // Check if class is selected
            if (!selectedClass) {
                reasons.push('No class selected');
            }
            
            // If we have both level and class, check other conditions
            if (selectedLevel && selectedClass) {
                // Read current ability scores
                const currentScores = {
                    STR: parseInt(document.getElementById('scoreSTR').value) || 3,
                    INT: parseInt(document.getElementById('scoreINT').value) || 3,
                    WIS: parseInt(document.getElementById('scoreWIS').value) || 3,
                    DEX: parseInt(document.getElementById('scoreDEX').value) || 3,
                    CON: parseInt(document.getElementById('scoreCON').value) || 3,
                    CHA: parseInt(document.getElementById('scoreCHA').value) || 3
                };
                
                // Check class ability requirements
                const requirements = {
                    'Cleric': {},
                    'Fighter': {},
                    'Magic-User': {},
                    'Thief': {},
                    'Dwarf': { CON: 9 },
                    'Elf': { INT: 9 },
                    'Halfling': { CON: 9, DEX: 9 },
                    'Gnome': { INT: 9 },
                    'Spellblade': { STR: 9, INT: 9 }
                };
                
                const classReqs = requirements[selectedClass] || {};
                Object.entries(classReqs).forEach(([ability, minScore]) => {
                    if (currentScores[ability] < minScore) {
                        reasons.push(`${ability} must be ≥ ${minScore} for ${selectedClass}`);
                    }
                });
                
                // Check for impossible Healthy Characters combination
                if (healthyCharacters && !includeLevel0HP) {
                    const conModifier = calculateModifier(currentScores.CON);
                    const hitDiceSizes = {
                        'Cleric': 6,
                        'Fighter': 8,
                        'Magic-User': 4,
                        'Thief': 4,
                        'Dwarf': 8,
                        'Elf': 6,
                        'Halfling': 6,
                        'Gnome': 4,
                        'Spellblade': 6
                    };
                    const hitDiceSize = hitDiceSizes[selectedClass] || 8;
                    const maxHP = hitDiceSize + conModifier;
                    
                    if (maxHP < 2) {
                        reasons.push(`Healthy Characters impossible: max HP = ${maxHP} (1d${hitDiceSize} + ${formatModifier(conModifier)})`);
                    }
                }
            }
            
            return {
                canRoll: reasons.length === 0,
                reasons: reasons
            };
        }
        
        // Update test HP button state
        function updateTestHPButton() {
            const testHPButton = document.getElementById('testHPButton');
            const testHPWarning = document.getElementById('testHPWarning');
            const testHPWarningText = document.getElementById('testHPWarningText');
            
            const result = canRollHP();
            
            if (result.canRoll) {
                testHPButton.disabled = false;
                testHPWarning.style.display = 'none';
            } else {
                testHPButton.disabled = true;
                testHPWarning.style.display = 'block';
                testHPWarningText.textContent = result.reasons.join('; ');
            }
        }
        
        // Update UI based on selections
        function updateUI() {
            updateXPBonus();
            updateTestHPButton();
            // Show/hide Spellblade button based on mode
            const spellbladeButton = document.getElementById('spellbladeButton');
            if (smoothifiedMode) {
                spellbladeButton.style.display = 'inline-block';
            } else {
                spellbladeButton.style.display = 'none';
                // Deselect Spellblade if it was selected
                if (selectedClass === 'Spellblade') {
                    selectedClass = null;
                    spellbladeButton.classList.remove('selected');
                }
            }

            // Check if demihuman class exceeds level limit (Normal Mode only)
            const demihumanLimits = {
                'Dwarf': 12,
                'Elf': 10,
                'Halfling': 8,
                'Gnome': 8
            };

            // Disable class buttons if level exceeds limit (Normal Mode only)
            if (!smoothifiedMode && !allowDemihumanOverride && selectedLevel) {
                document.querySelectorAll('.class-button').forEach(button => {
                    const className = button.dataset.class;
                    const limit = demihumanLimits[className];
                    if (limit && selectedLevel > limit) {
                        button.disabled = true;
                        if (selectedClass === className) {
                            selectedClass = null;
                            button.classList.remove('selected');
                        }
                    } else {
                        button.disabled = false;
                    }
                });
            } else {
                // Enable all buttons
                document.querySelectorAll('.class-button').forEach(button => {
                    button.disabled = false;
                });
            }

            // Enable generate button if level and class are selected
            const generateButton = document.getElementById('generateButton');
            generateButton.disabled = !(selectedLevel && selectedClass);
        }

        // Generate character (placeholder)
        function generateCharacter() {
            const characterInfo = document.getElementById('characterInfo');
            const characterDisplay = document.getElementById('characterDisplay');

            // Placeholder generation
            const mode = smoothifiedMode ? 'Smoothified' : 'Normal';
            const html = `
                <p><strong>Level:</strong> ${selectedLevel}</p>
                <p><strong>Class:</strong> ${selectedClass}</p>
                <p><strong>Mode:</strong> ${mode}</p>
                <p><strong>Demihuman Override:</strong> ${allowDemihumanOverride ? 'Yes' : 'No'}</p>
                <p><strong>Elf/Spellblade Past Level 10:</strong> ${allowElfSpellbladePast10 ? 'Yes' : 'No'}</p>
                <p><strong>Tough Guys:</strong> ${toughGuys ? 'Yes' : 'No'}</p>
                <p><strong>Include Level 0 HP:</strong> ${includeLevel0HP ? 'Yes' : 'No'}</p>
                <hr>
                <p><em>Full character generation coming soon!</em></p>
                <p>This will include:</p>
                <ul>
                    <li>Ability scores (3d6 each)</li>
                    <li>Hit points (rolled for level)</li>
                    <li>Saving throws (from class data)</li>
                    <li>Attack bonus (from class data)</li>
                    <li>Spell slots (if spellcaster)</li>
                    <li>Thief skills (if thief)</li>
                    <li>Turn undead (if cleric)</li>
                    <li>Class abilities</li>
                    <li>Equipment</li>
                    <li>XP tracking</li>
                </ul>
            `;

            characterInfo.innerHTML = html;
            characterDisplay.classList.add('visible');
            characterDisplay.scrollIntoView({ behavior: 'smooth' });
        }

        // Dice rolling function
        function rollDice(numDice, sides) {
            let total = 0;
            for (let i = 0; i < numDice; i++) {
                total += Math.floor(Math.random() * sides) + 1;
            }
            return total;
        }
        
        // Roll a single die and return the result
        function rollSingleDie(sides) {
            return Math.floor(Math.random() * sides) + 1;
        }
        
        // Parse hit dice string (e.g., "3d8", "9d8+2*", "1d6")
        function parseHitDice(hitDiceString) {
            // Check if hitDiceString is null or undefined
            if (!hitDiceString) {
                console.error(`Hit dice string is null or undefined`);
                return { numDice: 1, sides: 8, bonus: 0, noConModifier: false };
            }
            
            // Remove any asterisk (indicates CON modifier no longer applies)
            const cleanString = hitDiceString.replace('*', '');
            
            // Match pattern like "3d8" or "9d8+2"
            const match = cleanString.match(/(\d+)d(\d+)([+-]\d+)?/);
            if (!match) {
                console.error(`Invalid hit dice string: ${hitDiceString}`);
                return { numDice: 1, sides: 8, bonus: 0, noConModifier: hitDiceString.includes('*') };
            }
            
            return {
                numDice: parseInt(match[1]),
                sides: parseInt(match[2]),
                bonus: match[3] ? parseInt(match[3]) : 0,
                noConModifier: hitDiceString.includes('*')
            };
        }
        
        // Get class-specific features (spell slots, thief skills, turn undead, class abilities)
        function getClassFeatures(className, level) {
            console.log('\n=== Getting Class-Specific Features ===');
            console.log(`Class: ${className}, Level: ${level}`);
            
            // Get class data module based on mode
            const classData = smoothifiedMode ? ClassDataGygar : ClassDataOSE;
            
            // Add _CLASS suffix for class data lookup
            const classNameWithSuffix = className + '_CLASS';
            
            const features = {
                spellSlots: null,
                thiefSkills: null,
                turnUndead: null,
                classAbilities: []
            };
            
            // Check if class is a spellcaster
            const spellcasters = ['Cleric', 'Magic-User', 'Elf', 'Gnome', 'Spellblade'];
            if (spellcasters.includes(className)) {
                features.spellSlots = classData.getSpellSlots(classNameWithSuffix, level);
                console.log('\nSpell Slots:');
                if (features.spellSlots) {
                    Object.entries(features.spellSlots).forEach(([spellLevel, slots]) => {
                        if (slots > 0) {
                            console.log(`  Level ${spellLevel}: ${slots} slots`);
                        }
                    });
                } else {
                    console.log('  No spell slots at this level');
                }
            }
            
            // Check if class is Thief
            if (className === 'Thief') {
                features.thiefSkills = classData.getThiefSkills(level);
                console.log('\nThief Skills:');
                if (features.thiefSkills) {
                    Object.entries(features.thiefSkills).forEach(([skill, value]) => {
                        console.log(`  ${skill}: ${value}%`);
                    });
                }
            }
            
            // Check if class is Cleric
            if (className === 'Cleric') {
                // Get turn undead for all undead types
                const undeadTypes = [
                    'Skeleton', 'Zombie', 'Ghoul', 'Wight', 'Wraith', 
                    'Mummy', 'Spectre', 'Vampire'
                ];
                features.turnUndead = {};
                console.log('\nTurn Undead:');
                undeadTypes.forEach(type => {
                    const target = classData.getTurnUndead(level, type);
                    features.turnUndead[type] = target;
                    if (target === 'T') {
                        console.log(`  ${type}: T (automatically turned)`);
                    } else if (target === 'D') {
                        console.log(`  ${type}: D (automatically destroyed)`);
                    } else if (target === '-') {
                        console.log(`  ${type}: - (cannot turn)`);
                    } else {
                        console.log(`  ${type}: ${target}+ (roll d20)`);
                    }
                });
            }
            
            // Get class abilities from class-data-shared.js
            const allAbilities = ClassDataShared.getAbilitiesAtLevel(classNameWithSuffix, level);
            if (allAbilities && allAbilities.length > 0) {
                features.classAbilities = allAbilities;
                console.log('\nClass Abilities:');
                allAbilities.forEach(ability => {
                    console.log(`  - ${ability.name}: ${ability.description}`);
                });
            }
            
            console.log('======================================\n');
            
            return features;
        }
        
        // Get class progression data (saving throws, attack bonus, XP)
        function getClassProgressionData(className, level) {
            console.log('\n=== Getting Class Progression Data ===');
            console.log(`Class: ${className}, Level: ${level}`);
            
            // Get class data module based on mode
            const classData = smoothifiedMode ? ClassDataGygar : ClassDataOSE;
            
            // Add _CLASS suffix for class data lookup
            const classNameWithSuffix = className + '_CLASS';
            
            // Get saving throws
            const savingThrows = classData.getSavingThrows(classNameWithSuffix, level);
            console.log('\nSaving Throws:');
            console.log(`  Death/Poison: ${savingThrows.death}`);
            console.log(`  Wands: ${savingThrows.wands}`);
            console.log(`  Paralysis/Petrify: ${savingThrows.paralysis}`);
            console.log(`  Breath Attacks: ${savingThrows.breath}`);
            console.log(`  Spells/Rods/Staves: ${savingThrows.spells}`);
            
            // Get attack bonus
            const attackBonus = classData.getAttackBonus(classNameWithSuffix, level);
            console.log(`\nAttack Bonus: ${attackBonus >= 0 ? '+' : ''}${attackBonus}`);
            
            // Get XP requirements
            const currentXP = 0; // New character starts at 0 XP
            const xpForCurrentLevel = classData.getXPRequired(classNameWithSuffix, level);
            const xpForNextLevel = classData.getXPRequired(classNameWithSuffix, level + 1);
            const xpToNextLevel = xpForNextLevel ? xpForNextLevel - currentXP : null;
            
            console.log(`\nXP Tracking:`);
            console.log(`  Current XP: ${currentXP}`);
            console.log(`  XP for Level ${level}: ${xpForCurrentLevel}`);
            if (xpForNextLevel) {
                console.log(`  XP for Level ${level + 1}: ${xpForNextLevel}`);
                console.log(`  XP to Next Level: ${xpToNextLevel}`);
            } else {
                console.log(`  Maximum level reached!`);
            }
            
            // Get prime requisite XP bonus (already calculated in Phase 7A)
            const primeReqs = getPrimeRequisites(className);
            let xpBonus = 0;
            if (primeReqs.length > 0) {
                let totalBonus = 0;
                primeReqs.forEach(ability => {
                    const score = abilityScores[ability];
                    totalBonus += calculateXPBonus(score);
                });
                xpBonus = Math.floor(totalBonus / primeReqs.length);
            }
            console.log(`  Prime Requisite XP Bonus: ${xpBonus >= 0 ? '+' : ''}${xpBonus}%`);
            
            console.log('======================================\n');
            
            return {
                savingThrows,
                attackBonus,
                currentXP,
                xpForCurrentLevel,
                xpForNextLevel,
                xpToNextLevel,
                xpBonus
            };
        }
        
        // Roll hit points for a character
        function rollHitPoints(className, level, conModifier) {
            console.log('\n=== Rolling Hit Points ===');
            console.log(`Class: ${className}, Level: ${level}, CON Modifier: ${formatModifier(conModifier)}`);
            
            // Get class data module based on mode
            const classData = smoothifiedMode ? ClassDataGygar : ClassDataOSE;
            
            let totalHP = 0;
            let level0HP = 0;
            
            // Roll Level 0 HP if enabled
            if (includeLevel0HP) {
                console.log('\n--- Level 0 HP ---');
                let l0Roll, l0HP;
                let l0Attempts = 0;
                
                do {
                    l0Attempts++;
                    l0Roll = rollSingleDie(4);
                    l0HP = l0Roll + conModifier;
                    
                    if (l0HP < 1) l0HP = 1; // Minimum 1 HP
                    
                    if (healthyCharacters && l0HP < 2) {
                        console.log(`  Level 0: [${l0Roll}] + ${formatModifier(conModifier)} = ${l0HP} (below minimum 2, rerolling...)`);
                    }
                } while (healthyCharacters && l0HP < 2);
                
                console.log(`  Level 0: [${l0Roll}] + ${formatModifier(conModifier)} = ${l0HP}`);
                if (healthyCharacters && l0Attempts > 1) {
                    console.log(`  ✅ Passed Healthy Characters check after ${l0Attempts} attempts`);
                }
                
                level0HP = l0HP;
                totalHP += l0HP;
            }
            
            // Roll HP for each level from 1 to selected level
            console.log(`\n--- Rolling HP for Levels 1-${level} ---`);
            
            for (let lvl = 1; lvl <= level; lvl++) {
                // Add _CLASS suffix for class data lookup
                const classNameWithSuffix = className + '_CLASS';
                const hitDiceString = classData.getHitDice(classNameWithSuffix, lvl);
                const hitDice = parseHitDice(hitDiceString);
                
                let levelHP, rolls;
                let attempts = 0;
                
                do {
                    attempts++;
                    rolls = [];
                    levelHP = hitDice.bonus; // Start with any fixed bonus
                    
                    // Roll ONE die per level (not numDice)
                    const die = rollSingleDie(hitDice.sides);
                    rolls.push(die);
                    levelHP += die;
                    
                    // Apply CON modifier (unless hit dice has asterisk)
                    if (!hitDice.noConModifier) {
                        levelHP += conModifier;
                    }
                    
                    // Minimum 1 HP per level
                    if (levelHP < 1) levelHP = 1;
                    
                    // Apply Healthy Characters to level 1 HP only (if not using level 0 HP)
                    if (lvl === 1 && !includeLevel0HP && healthyCharacters && levelHP < 2) {
                        const conPart = hitDice.noConModifier ? '' : ` + ${formatModifier(conModifier)}`;
                        console.log(`  Level ${lvl}: [${rolls.join(', ')}]${conPart} = ${levelHP} (below minimum 2, rerolling...)`);
                    }
                } while (lvl === 1 && !includeLevel0HP && healthyCharacters && levelHP < 2);
                
                // Log the roll
                const conPart = hitDice.noConModifier ? '' : ` + ${formatModifier(conModifier)}`;
                const bonusPart = hitDice.bonus !== 0 ? ` + ${hitDice.bonus}` : '';
                console.log(`  Level ${lvl}: [${rolls.join(', ')}]${bonusPart}${conPart} = ${levelHP}`);
                
                if (lvl === 1 && !includeLevel0HP && healthyCharacters && attempts > 1) {
                    console.log(`  ✅ Passed Healthy Characters check after ${attempts} attempts`);
                }
                
                totalHP += levelHP;
            }
            
            // Summary
            console.log('\n--- Hit Points Summary ---');
            if (includeLevel0HP) {
                console.log(`Level 0 HP: ${level0HP}`);
                console.log(`Levels 1-${level} HP: ${totalHP - level0HP}`);
            }
            console.log(`Total HP: ${totalHP}`);
            console.log('==========================\n');
            
            return totalHP;
        }
        
        // Roll a single ability score (3d6) with detailed logging
        function rollAbilityScore(minimum, abilityName) {
            let score, rolls;
            let attempts = 0;
            do {
                attempts++;
                rolls = [];
                score = 0;
                for (let i = 0; i < 3; i++) {
                    const die = Math.floor(Math.random() * 6) + 1;
                    rolls.push(die);
                    score += die;
                }
                if (score < minimum) {
                    console.log(`  ${abilityName}: [${rolls.join(', ')}] = ${score} (below minimum ${minimum}, rerolling...)`);
                }
            } while (score < minimum);
            
            console.log(`  ${abilityName}: [${rolls.join(', ')}] = ${score}`);
            return score;
        }
        
        // Check if scores meet Tough Characters requirements
        // At least ONE of STR/DEX/INT/WIS must be ≥ 13
        function meetsToughCharactersRequirements(scores) {
            return scores.STR >= 13 || scores.DEX >= 13 || 
                   scores.INT >= 13 || scores.WIS >= 13;
        }
        
        // Roll all ability scores
        function rollAbilities() {
            let scores;
            let setAttempts = 0;
            
            console.log('=== Rolling Ability Scores ===');
            if (toughCharacters) {
                console.log('Tough Characters enabled: At least one of STR/DEX/INT/WIS must be ≥ 13');
            }
            
            do {
                setAttempts++;
                if (setAttempts > 1) {
                    console.log(`\nAttempt #${setAttempts} (previous set failed Tough Characters check):`);
                } else {
                    console.log('\nRolling 3d6 for each ability:');
                }
                
                scores = {
                    STR: rollAbilityScore(minimumScores.STR, 'STR'),
                    INT: rollAbilityScore(minimumScores.INT, 'INT'),
                    WIS: rollAbilityScore(minimumScores.WIS, 'WIS'),
                    DEX: rollAbilityScore(minimumScores.DEX, 'DEX'),
                    CON: rollAbilityScore(minimumScores.CON, 'CON'),
                    CHA: rollAbilityScore(minimumScores.CHA, 'CHA')
                };
                
                if (toughCharacters && !meetsToughCharactersRequirements(scores)) {
                    console.log('❌ Failed Tough Characters check (need at least one of STR/DEX/INT/WIS ≥ 13)');
                }
            } while (toughCharacters && !meetsToughCharactersRequirements(scores));
            
            if (toughCharacters && setAttempts > 1) {
                console.log(`✅ Passed Tough Characters check after ${setAttempts} attempts`);
            }
            
            console.log('\n=== Final Ability Scores ===');
            console.log(`STR: ${scores.STR} (${formatModifier(calculateModifier(scores.STR))})`);
            console.log(`INT: ${scores.INT} (${formatModifier(calculateModifier(scores.INT))})`);
            console.log(`WIS: ${scores.WIS} (${formatModifier(calculateModifier(scores.WIS))})`);
            console.log(`DEX: ${scores.DEX} (${formatModifier(calculateModifier(scores.DEX))})`);
            console.log(`CON: ${scores.CON} (${formatModifier(calculateModifier(scores.CON))})`);
            console.log(`CHA: ${scores.CHA} (${formatModifier(calculateModifier(scores.CHA))})`);
            console.log('==============================\n');
            
            // Update state
            abilityScores = scores;
            
            // Update UI
            document.getElementById('scoreSTR').value = scores.STR;
            document.getElementById('scoreINT').value = scores.INT;
            document.getElementById('scoreWIS').value = scores.WIS;
            document.getElementById('scoreDEX').value = scores.DEX;
            document.getElementById('scoreCON').value = scores.CON;
            document.getElementById('scoreCHA').value = scores.CHA;
            
            // Trigger modifiers update
            updateModifiers();
        }
        
        // Calculate ability modifier (-3 to +3)
        function calculateModifier(score) {
            if (score <= 3) return -3;
            if (score <= 5) return -2;
            if (score <= 8) return -1;
            if (score <= 12) return 0;
            if (score <= 15) return 1;
            if (score <= 17) return 2;
            return 3; // 18
        }
        
        // Format modifier for display
        function formatModifier(mod) {
            return mod >= 0 ? `+${mod}` : `${mod}`;
        }
        
        // Calculate XP bonus from prime requisite
        function calculateXPBonus(score) {
            if (score <= 5) return -20;
            if (score <= 8) return -10;
            if (score <= 12) return 0;
            if (score <= 15) return 5;
            return 10; // 16+
        }
        
        // Get prime requisites for a class
        function getPrimeRequisites(className) {
            const primeReqs = {
                'Cleric': ['WIS'],
                'Fighter': ['STR'],
                'Magic-User': ['INT'],
                'Thief': ['DEX'],
                'Dwarf': ['STR'],
                'Elf': ['STR', 'INT'],
                'Halfling': ['STR', 'DEX'],
                'Gnome': ['INT'],
                'Spellblade': ['STR', 'INT']
            };
            return primeReqs[className] || [];
        }
        
        // Update ability modifiers display
        function updateModifiers() {
            ['STR', 'INT', 'WIS', 'DEX', 'CON', 'CHA'].forEach(ability => {
                const score = parseInt(document.getElementById(`score${ability}`).value) || 3;
                const modifier = calculateModifier(score);
                document.getElementById(`mod${ability}`).textContent = formatModifier(modifier);
            });
            
            updateXPBonus();
            updateTestHPButton();
        }
        
        // Update XP bonus display
        function updateXPBonus() {
            if (!selectedClass) {
                document.getElementById('xpBonusDisplay').style.display = 'none';
                return;
            }
            
            const primeReqs = getPrimeRequisites(selectedClass);
            if (primeReqs.length === 0) {
                document.getElementById('xpBonusDisplay').style.display = 'none';
                return;
            }
            
            // For classes with multiple prime requisites, use the average
            let totalBonus = 0;
            primeReqs.forEach(ability => {
                const score = parseInt(document.getElementById(`score${ability}`).value) || 3;
                totalBonus += calculateXPBonus(score);
            });
            const avgBonus = Math.floor(totalBonus / primeReqs.length);
            
            const bonusText = avgBonus >= 0 ? `+${avgBonus}%` : `${avgBonus}%`;
            document.getElementById('xpBonusText').textContent = bonusText;
            document.getElementById('xpBonusDisplay').style.display = 'block';
        }
        
        // Read ability scores from inputs
        function readAbilityScores() {
            abilityScores = {
                STR: parseInt(document.getElementById('scoreSTR').value) || 3,
                INT: parseInt(document.getElementById('scoreINT').value) || 3,
                WIS: parseInt(document.getElementById('scoreWIS').value) || 3,
                DEX: parseInt(document.getElementById('scoreDEX').value) || 3,
                CON: parseInt(document.getElementById('scoreCON').value) || 3,
                CHA: parseInt(document.getElementById('scoreCHA').value) || 3
            };
            updateModifiers();
        }
        
        // Get minimum scores - always use 3 as the minimum when rolling
        function getMinimumScores() {
            // Always use 3 as minimum for rolling
            // The input fields show the rolled results, not the minimums
            return {
                STR: 3,
                INT: 3,
                WIS: 3,
                DEX: 3,
                CON: 3,
                CHA: 3
            };
        }
        
        // Update Roll Abilities button state
        function updateRollButtonState() {
            const rollButton = document.getElementById('rollAbilitiesButton');
            rollButton.disabled = useFixedScores;
        }

        // Event listeners
        document.getElementById('useFixedScores').addEventListener('change', (e) => {
            useFixedScores = e.target.checked;
            updateRollButtonState();
        });
        
        document.getElementById('rollAbilitiesButton').addEventListener('click', () => {
            // Always use 3 as minimum when rolling
            minimumScores = {
                STR: 3,
                INT: 3,
                WIS: 3,
                DEX: 3,
                CON: 3,
                CHA: 3
            };
            rollAbilities();
        });
        
        // Test HP rolling button
        document.getElementById('testHPButton').addEventListener('click', () => {
            if (!selectedLevel || !selectedClass) {
                alert('Please select a level and class first!');
                return;
            }
            
            // Read current ability scores
            readAbilityScores();
            
            // Get CON modifier
            const conModifier = calculateModifier(abilityScores.CON);
            
            // Roll HP
            const totalHP = rollHitPoints(selectedClass, selectedLevel, conModifier);
            
            // Get class progression data
            const progressionData = getClassProgressionData(selectedClass, selectedLevel);
            
            // Get class-specific features
            const classFeatures = getClassFeatures(selectedClass, selectedLevel);
        });
        
        // Add event listeners to ability score inputs
        ['STR', 'INT', 'WIS', 'DEX', 'CON', 'CHA'].forEach(ability => {
            const input = document.getElementById(`score${ability}`);
            input.addEventListener('change', readAbilityScores);
            input.addEventListener('input', updateModifiers); // Update modifiers as user types
        });
        
        document.getElementById('smoothifiedMode').addEventListener('change', (e) => {
            smoothifiedMode = e.target.checked;
            updateUI();
        });

        document.getElementById('allowDemihumanOverride').addEventListener('change', (e) => {
            allowDemihumanOverride = e.target.checked;
            updateUI();
        });

        document.getElementById('allowElfSpellbladePast10').addEventListener('change', (e) => {
            allowElfSpellbladePast10 = e.target.checked;
            updateUI();
        });

        document.getElementById('toughCharacters').addEventListener('change', (e) => {
            toughCharacters = e.target.checked;
        });

        document.getElementById('healthyCharacters').addEventListener('change', (e) => {
            healthyCharacters = e.target.checked;
            updateTestHPButton();
        });

        document.getElementById('includeLevel0HP').addEventListener('change', (e) => {
            includeLevel0HP = e.target.checked;
            updateTestHPButton();
        });

        document.getElementById('generateButton').addEventListener('click', generateCharacter);

        // Initialize
        initializeLevelSelection();
        initializeClassSelection();
        updateRollButtonState();
        updateModifiers(); // Initialize modifiers
        updateUI();
    </script>

</body>
</html>
